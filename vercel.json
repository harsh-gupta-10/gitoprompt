{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "nodejs": "20.x",
  "rewrites": [
    {
      "source": "/api/nvidia/(.*)",
      "destination": "https://integrate.api.nvidia.com/:1*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
